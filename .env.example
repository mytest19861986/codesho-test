DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-each-environment
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost
DATABASE_RUNTIME_URL=postgresql://codesho_runtime:codesho-runtime-local@postgres:5432/codesho
DATABASE_MIGRATOR_URL=postgresql://codesho_migrator:codesho-migrator-local@postgres:5432/codesho
CODESHO_RUNTIME_PASSWORD=codesho-runtime-local
CODESHO_MIGRATOR_PASSWORD=codesho-migrator-local
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
TENANT_BASE_DOMAIN=localhost
PASSCODE_ACTIVE_PEPPER_ID=v1
# Replace with a randomly generated base64 value containing at least 32 bytes.
PASSCODE_PEPPERS={"v1":"QUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUE="}
PASSCODE_SIGNAL_HMAC_KEY=QUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUE=
PASSCODE_ATTEMPT_WINDOW_SECONDS=900
PASSCODE_ACCOUNT_MAX_FAILURES=5
PASSCODE_LOCKOUT_SECONDS=900
PASSCODE_IP_MAX_FAILURES=30
PASSCODE_DEVICE_MAX_FAILURES=20
PASSCODE_GLOBAL_ALERT_THRESHOLD=1000
PASSCODE_GLOBAL_WINDOW_SECONDS=300
PASSCODE_PROGRESSIVE_DELAYS_MS=250,500,1000,2000
PASSCODE_RATE_LIMIT_REDIS_PREFIX=codesho:passcode:v1
PASSCODE_BACKEND_FAILURE_RETRY_SECONDS=5
TRUSTED_PROXY_CIDRS=
PASSCODE_DEVICE_COOKIE_NAME=codesho_device
PASSCODE_DEVICE_MAX_AGE_SECONDS=2592000
SESSION_COOKIE_AGE=43200
NGINX_HOST_PORT=80
